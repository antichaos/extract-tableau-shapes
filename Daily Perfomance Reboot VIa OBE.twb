      <column caption='running rate label - month' datatype='real' default-format='p0%' name='[Calculation_4567705564212731913]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 7]&#10;&#10;WHEN 0 THEN NULL&#10;WHEN 1 THEN IF LAST()==0 THEN &#10;RUNNING_SUM(SUM(SALES))/&#10;RUNNING_SUM(SUM([SIGNUPS]))&#10;END&#10;WHEN 2 THEN IF RANK_UNIQUE(&#10;RUNNING_SUM(SUM(SALES))/&#10;RUNNING_SUM(SUM([SIGNUPS])),&apos;asc&apos;) &lt; 3 &#10;OR&#10;RANK_UNIQUE(&#10;RUNNING_SUM(SUM(SALES))/&#10;RUNNING_SUM(SUM([SIGNUPS])),&apos;desc&apos;) &lt; 3&#10;OR&#10;LAST()==0&#10;&#10; THEN &#10;RUNNING_SUM(SUM(SALES))/&#10;RUNNING_SUM(SUM([SIGNUPS]))&#10;END&#10;&#10;&#10;&#10;WHEN 3 THEN &#10;RUNNING_SUM(SUM(SALES))/&#10;RUNNING_SUM(SUM([SIGNUPS]))&#10;&#10;&#10;&#10;END'>
          <table-calc ordering-type='Rows' />
