            </column>
            <column caption='main_channel label' datatype='string' name='[Calculation_1365575913192280064]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ISNULL([MAIN_CHANNEL]) OR [MAIN_CHANNEL] = &quot;Other&quot; THEN &quot;Other&quot;&#10;ELSEIF [MAIN_CHANNEL] =  &quot;TeleMarketing&quot; THEN &quot;TM&quot;&#10;ELSEIF [MAIN_CHANNEL] =  &quot;FieldMarketing&quot; THEN &quot;FM&quot;&#10;ELSEIF [MAIN_CHANNEL] =  &quot;Door to Door&quot; THEN &quot;D2D&quot;&#10;ELSE [MAIN_CHANNEL]&#10;&#10;END' />
            </column>
            <column caption='_Metric ' datatype='integer' name='[Calculation_1595400184343027723]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='case[Parameters].[Parameter 3]&#13;&#10;    when 1 then SUM([SALES])&#13;&#10;    when 2 then SUM([CANCELLATION])&#13;&#10;    when 3 then zn([Calculation_3365244457335033857])&#13;&#10;END' />
            </column>
            <column caption='Net Signups' datatype='integer' default-format='*+#,##0;-#,##0' name='[Calculation_3365244457335033857]' role='measure' type='quantitative'>
