      <column caption='_Yesterday_created_data_freshness' datatype='string' name='[_Yesterday_created (copy)_683139801340698624]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF &#13;&#10;    //GREEN if both sales and cancellations up to date to yesterday&#13;&#10;    [Calculation_683139801342271491] = DATETRUNC(&apos;day&apos;,NOW())-1&#13;&#10;        AND &#13;&#10;    [Calculation_683139801342484485] = DATETRUNC(&apos;day&apos;,NOW())-1&#13;&#10;    then &quot;GREEN&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;    IF &#13;&#10;    // IF signups or cancellations are update to date, but not both&#13;&#10;    [Calculation_683139801342271491] &gt;= DATETRUNC(&apos;day&apos;,NOW())-1&#13;&#10;        OR&#13;&#10;    [Calculation_683139801342484485] &gt;= DATETRUNC(&apos;day&apos;,NOW())-1&#13;&#10;    then &quot;AMBER&quot;&#13;&#10;&#13;&#10;ELSE&#13;&#10;    // RED if either records are &gt;2 days out of date&#13;&#10;IF &#13;&#10;    [Calculation_683139801342271491] &lt;= DATETRUNC(&apos;day&apos;,NOW())-2&#13;&#10;        OR&#13;&#10;    [Calculation_683139801342484485] &lt;= DATETRUNC(&apos;day&apos;,NOW())-2&#13;&#10;    then &quot;RED&quot;&#13;&#10;&#13;&#10;ELSE &#13;&#10;    // amber for any other permutations&#13;&#10;    &quot;AMBER&quot;&#13;&#10;&#13;&#10;END&#13;&#10;END&#13;&#10;END' />
      </column>
