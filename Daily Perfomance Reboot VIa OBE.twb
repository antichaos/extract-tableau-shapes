    <worksheet name='af_trend_Daily Figures | YoY'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontcolor='#355b7a' fontname='Tableau Semibold' fontsize='14'><![CDATA[<[Parameters].[Parameter 3]> | Year over Year]]></run>
            <run>Æ&#10;</run>
            <run bold='true' fontcolor='#f28e2b' fontname='Tableau Semibold' fontsize='9'><![CDATA[<[sqlproxy.1m2rcrd1kkgkyn126z5931ppaxl1].[tmn:Calculation_3365244457378168849:qk]> ]]></run>
            <run bold='true' fontcolor='#666666' fontname='Tableau Semibold' fontsize='9'>vs</run>
            <run bold='true' fontcolor='#f28e2b' fontname='Tableau Semibold' fontsize='9'>Æ </run>
            <run bold='true' fontcolor='#a7acad' fontname='Tableau Semibold' fontsize='9'><![CDATA[<[sqlproxy.1m2rcrd1kkgkyn126z5931ppaxl1].[tmn:mom - month label COMPARE (copy)_3365244457381924883:qk]>]]></run>
          </formatted-text>
        </title>
        <caption>
          <formatted-text>
            <run fontalignment='2'>Days to Draw ▶            </run>
          </formatted-text>
        </caption>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Daily Performance Report - Results &amp; Targets' name='sqlproxy.1m2rcrd1kkgkyn126z5931ppaxl1' />
            <datasource caption='Daily Performance Report - Results &amp; Targets (copy)' name='sqlproxy.1m2rcrd1kkgkyn126z5931ppaxl1 (copy)' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='_param | Lottery' datatype='string' default-value-field='[sqlproxy.1m2rcrd1kkgkyn126z5931ppaxl1 (copy)].[Calculation_4447938013405458446]' name='[Parameter 1 1]' param-domain-type='list' role='measure' source-field='[sqlproxy.1m2rcrd1kkgkyn126z5931ppaxl1].[LOTTERY]' type='nominal' value='&quot;NPL&quot;'>
              <calculation class='tableau' formula='&quot;NPL&quot;' />
            </column>
            <column alias='Playround Month' caption='_param | Month Type' datatype='integer' datatype-customized='true' name='[Parameter 1]' param-domain-type='list' role='measure' type='quantitative' value='1'>
              <calculation class='tableau' formula='1' />
              <aliases>
                <alias key='1' value='Playround Month' />
                <alias key='2' value='Calendar Month' />
              </aliases>
            </column>
            <column alias='Sign Ups' caption='_param | Chart - Metric Selection' datatype='integer' datatype-customized='true' name='[Parameter 3]' param-domain-type='list' role='measure' type='quantitative' value='1'>
              <calculation class='tableau' formula='1' />
              <aliases>
                <alias key='1' value='Sign Ups' />
                <alias key='2' value='Cancellations' />
                <alias key='3' value='Net Sign Ups' />
              </aliases>
            </column>
            <column caption='_param | month' datatype='date' default-format='*mmmm yyyy' name='[Parameter 7 2]' param-domain-type='list' role='measure' source-field='[sqlproxy.1m2rcrd1kkgkyn126z5931ppaxl1].[PLAYROUND]' type='quantitative' value='#2024-10-01#'>
              <calculation class='tableau' formula='#2024-10-01#' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='sqlproxy.1m2rcrd1kkgkyn126z5931ppaxl1'>
            <column aggregation='Sum' caption='CANCELLATIONS' datatype='integer' default-type='quantitative' layered='true' name='[CANCELLATION]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column aggregation='Year' datatype='date' default-type='ordinal' layered='true' name='[CREATED_DATE]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default' />
            <column aggregation='Year' datatype='date' default-type='ordinal' layered='true' name='[CUT_OFF_DATE_1]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default' />
            <column caption='_Month (draw/create)' datatype='date' name='[Calculation_1235675163283988481]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATE(If [Parameters].[Parameter 1] = 1&#13;&#10;    Then DATETRUNC(&apos;month&apos;,[PLAYROUND])&#13;&#10;ElseIf [Parameters].[Parameter 1] = 2&#13;&#10;    Then DateTrunc(&apos;month&apos;,[CREATED_DATE])&#13;&#10;End)' />
            </column>
            <column caption='_Metric ' datatype='integer' name='[Calculation_1595400184343027723]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='case[Parameters].[Parameter 3]&#13;&#10;    when 1 then SUM([SALES])&#13;&#10;    when 2 then SUM([CANCELLATION])&#13;&#10;    when 3 then zn([Calculation_3365244457335033857])&#13;&#10;END' />
            </column>
            <column caption='Net Signups' datatype='integer' default-format='*+#,##0;-#,##0' name='[Calculation_3365244457335033857]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(ZN([SALES]))-SUM(ZN([CANCELLATION]))' />
            </column>
            <column caption='mom - month label SEL' datatype='datetime' name='[Calculation_3365244457378168849]' role='dimension' type='quantitative'>
              <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,IF [_Month yeardiff (copy)_3365244457351528455] == 0 THEN [Calculation_1235675163283988481] END)' />
            </column>
            <column caption='Cutoff Date' datatype='date' name='[Calculation_4567705564282544139]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='{FIXED [PLAYROUND]: MIN([CUT_OFF_DATE_1])}' />
            </column>
            <column caption='Days Cut off' datatype='integer' name='[Calculation_4567705564282654732]' role='dimension' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [PLAYROUND]: MIN(IF [Calculation_4567705564282544139] = [CREATED_DATE] THEN [DAYS] END)}' />
            </column>
            <column caption='Days Cut Off - TM' datatype='integer' name='[Calculation_4567705564286885902]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Selected Month (Draw)] THEN [Calculation_4567705564282654732] END' />
            </column>
            <column caption='Selected Playround Month + Same Month LY' datatype='boolean' name='[Calculation_5490099063276163075]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[PLAYROUND])  = DATETRUNC(&apos;month&apos;,[Parameters].[Parameter 7 2])&#10;OR&#10;DATETRUNC(&apos;month&apos;,[PLAYROUND])  = DATETRUNC(&apos;month&apos;,DATEADD(&apos;year&apos;,-1,[Parameters].[Parameter 7 2]))' />
            </column>
            <column aggregation='Sum' caption='DAYS_PRIOR_TO_DRAW' datatype='integer' default-type='quantitative' layered='true' name='[DAYS]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column caption='Days Cut Off - LM' datatype='integer' name='[Days Cut Off - TM (copy)_4567705564287004687]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF NOT [Selected Month (Draw)] THEN [Calculation_4567705564282654732] END' />
            </column>
            <column aggregation='Count' datatype='string' default-type='nominal' layered='true' name='[LOTTERY]' pivot='key' role='dimension' type='nominal' user-datatype='string' visual-totals='Default' />
            <column aggregation='Year' datatype='date' default-type='ordinal' layered='true' name='[PLAYROUND]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default' />
            <column caption='Playround String (diff)' datatype='boolean' name='[Playround String (copy)_5490099063282208773]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='STR(YEAR([PLAYROUND])) +&quot;-&quot; + STR(MONTH([PLAYROUND])) +&quot;-&quot; + STR(DAY([PLAYROUND]))&#10;=&#10;STR(YEAR([Parameters].[Parameter 7 2])) +&quot;-&quot; + STR(MONTH([Parameters].[Parameter 7 2])) +&quot;-&quot; + STR(DAY([Parameters].[Parameter 7 2]))' />
            </column>
            <column aggregation='Sum' datatype='integer' default-type='quantitative' layered='true' name='[SALES]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
            <column caption='_Month month diff ' datatype='integer' name='[_Month yeardiff (copy)_3365244457351528455]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATEDIFF(&apos;month&apos;,[Calculation_1235675163283988481],[Parameters].[Parameter 7 2])' />
            </column>
            <column caption='yoy - month label COMPARE' datatype='datetime' name='[mom - month label COMPARE (copy)_3365244457381924883]' role='dimension' type='quantitative'>
              <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,IF [_Month yeardiff (copy)_3365244457351528455] == 12 THEN [Calculation_1235675163283988481] END)' />
            </column>
            <column-instance column='[Calculation_4567705564286885902]' derivation='None' name='[none:Calculation_4567705564286885902:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_5490099063276163075]' derivation='None' name='[none:Calculation_5490099063276163075:nk]' pivot='key' type='nominal' />
            <column-instance column='[DAYS]' derivation='None' name='[none:DAYS:qk]' pivot='key' type='quantitative' />
