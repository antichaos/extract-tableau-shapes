      <column caption='_____yesterday' datatype='boolean' hidden='true' name='[Calculation_1030761382458265614]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='case [Parameters].[Parameter 3 1]&#13;&#10;when &apos;Sign ups&apos; then&#13;&#10;{&#13;&#10;   FIXED [LOTTERY]: Max( &#13;&#10;            If Not IsNull([SALES]) &#13;&#10;                Then [CREATED_DATE]&#13;&#10;            End&#13;&#10;        )&#13;&#10;} = DATEADD(&apos;day&apos;, -1, TODAY())&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Sales vs Target T/F' datatype='boolean' hidden='true' name='[Calculation_1056938542402387969]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1484780519916171266] &gt; 1' />
