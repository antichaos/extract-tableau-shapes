            <column caption='_Lottery_Logo_filtered' datatype='boolean' name='[Calculation_1595400184336211978]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[LOTTERY]=[Parameters].[Parameter 1 1]' />
            </column>
            <column caption='Sales vs Target to Date  CAL (running) :LABEL' datatype='real' default-format='p0%' name='[Calculation_4567705564217274378]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 7]&#10;WHEN 0 THEN NULL&#10;WHEN 1 THEN IF LAST()==0 THEN [Sales vs Target to Date  CAL (copy)_222294869565788191] END&#10;WHEN 2 THEN IF LAST()==0 OR &#10;RANK_DENSE([Sales vs Target to Date  CAL (copy)_222294869565788191],&apos;desc&apos;) &lt;= 3&#10;OR&#10;RANK_DENSE([Sales vs Target to Date  CAL (copy)_222294869565788191],&apos;asc&apos;) &lt;= 3&#10;THEN [Sales vs Target to Date  CAL (copy)_222294869565788191] END&#10;WHEN 3 THEN [Sales vs Target to Date  CAL (copy)_222294869565788191] &#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Last value sales vs target tot date' datatype='real' default-format='p0.0%' name='[Calculation_6254303620800954374]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='WINDOW_MAX(IF LAST()==0 THEN [Sales vs Target to Date  CAL (copy)_222294869565788191] END)'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Filter: This Month  (caldate) ' datatype='boolean' name='[Filter: This Month  (drawdate) (copy)_222294869560279067]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,[Parameters].[Parameter 7 2]) = DATETRUNC(&apos;month&apos;,[CREATED_DATE])' />
            </column>
            <column caption='Helper: SOM' datatype='date' name='[Helper: EOM (copy)_6254303620800040965]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATE(DATETRUNC(&apos;month&apos;,[Parameters].[Parameter 7 2]))' />
            </column>
            <column caption='Helper: EOM' datatype='datetime' name='[Helper: EOY (copy)_222294869570330661]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATEADD(&apos;month&apos;,1,&#10;DATE(DATETRUNC(&apos;month&apos;,[Parameters].[Parameter 7 2]))&#10;)&#10;-1' />
            </column>
            <column aggregation='Count' datatype='string' default-type='nominal' layered='true' name='[LOTTERY]' pivot='key' role='dimension' type='nominal' user-datatype='string' visual-totals='Default' />
            <column caption='Last value DATE sales vs target tot date' datatype='date' default-format='*d MMM yyyy' name='[Last value sales vs target tot date (copy)_6254303620801400839]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATE(WINDOW_MAX(IF LAST()==0 THEN MIN(DATETRUNC(&apos;day&apos;, DATETRUNC(&apos;day&apos;, [CREATED_DATE]))) END))'>
