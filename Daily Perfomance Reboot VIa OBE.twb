            <column caption='RUNNING_SUM(SUM(SALES))/RUNNING_SUM(SUM([SIGNUP_TARGET (MONTH...' datatype='real' name='[Calculation_4273845687539994628]' role='measure' type='quantitative' user:unnamed='Runrate per month SALES (2)'>
              <calculation class='tableau' formula='RUNNING_SUM(SUM(SALES))/RUNNING_SUM(SUM([SIGNUPS]))'>
