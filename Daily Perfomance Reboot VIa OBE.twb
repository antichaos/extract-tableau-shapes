              <calculation class='tableau' formula='[Filter: Yesterday  (copy)_222294869557858330]&#10;= &#10;[CREATED_DATE]' />
            </column>
            <column caption='Max Date Sales  (== &apos;yesterday&apos;)' datatype='date' name='[Filter: Yesterday  (copy)_222294869557858330]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='{FIXED [LOTTERY]: MAX(IF NOT ISNULL([SALES]) AND [CREATED_DATE] &lt; TODAY() THEN [CREATED_DATE] END) }' />
            </column>
            <column aggregation='Count' datatype='string' default-type='nominal' layered='true' name='[LOTTERY]' pivot='key' role='dimension' type='nominal' user-datatype='string' visual-totals='Default' />
            <column caption='Yesterday Sales to target - Calendar - Above' datatype='integer' name='[Monthly Sales to target - Calendar - Above (copy)_1429189203387732010]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF NOT ISNULL(SUM([SIGNUP_TARGET])) THEN &#10;IF&#10;    SUM([SALES]) &gt; SUM([SIGNUP_TARGET])&#10;THEN&#10;    SUM([SALES]) &#10;END&#10;END' />
            </column>
            <column caption='Yesterday Sales to target - Calendar - Under' datatype='integer' name='[Monthly Sales to target - Calendar - Under (copy)_1429189203387732011]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF NOT ISNULL(SUM([SIGNUP_TARGET])) THEN &#10;&#10;IF&#10;    SUM([SALES]) &lt; SUM([SIGNUPS])&#10;THEN&#10;    SUM([SALES]) &#10;END&#10;END' />
            </column>
            <column caption='Yesterday Sales to target - Calendar Diff' datatype='integer' name='[Monthly Sales to target - Calendar Diff (copy)_1429189203387732012]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF NOT ISNULL(SUM([SIGNUP_TARGET])) THEN &#10;&#10;IF&#10;    SUM([SALES]) &lt; SUM([SIGNUP_TARGET])&#10;THEN&#10;    SUM([SALES]) - SUM([SIGNUP_TARGET])&#10;END&#10;&#10;END' />
            </column>
