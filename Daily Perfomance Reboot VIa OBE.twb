        <calculation class='tableau' formula='CASE [Parameters].[Parameter 7]&#10;WHEN 0 THEN NULL&#10;WHEN 1 THEN &#10;   IF  RANK([Calculation_1595400184343027723],&apos;desc&apos;) =1 THEN [Calculation_1595400184343027723] END&#10;WHEN 2 THEN &#10;   IF  RANK([Calculation_1595400184343027723],&apos;desc&apos;) &lt;= 3 &#10;OR  RANK([Calculation_1595400184343027723],&apos;asc&apos;) &lt;= 3 &#10;&#10;THEN [Calculation_1595400184343027723] END&#10;&#10;WHEN 3 THEN &#10;   [Calculation_1595400184343027723] &#10;&#10;&#10;&#10;END'>
          <table-calc ordering-type='Rows' />
