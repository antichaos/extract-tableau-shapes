            <column caption='mom axis band - bottom (copy 2) (copy)' datatype='real' name='[mom axis band - bottom (copy 2) (copy)_2867737438858944516]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='WINDOW_MAX([Sales vs Target to Date  CAL (copy)_222294869565788191])&#10;+&#10;(&#10;WINDOW_MAX([Sales vs Target to Date  CAL (copy)_222294869565788191])&#10;-&#10;WINDOW_MIN([Sales vs Target to Date  CAL (copy)_222294869565788191])&#10;)/4'>
