            <column caption='RUNNING_SUM(SUM(SALES))/RUNNING_SUM(SUM([SIGNUP_TARGET (MONTH...' datatype='real' name='[Calculation_4273845687540051973]' role='measure' type='quantitative' user:unnamed='Runrate per month SALES (2)'>
              <calculation class='tableau' formula='RUNNING_SUM(SUM(SALES))/RUNNING_SUM(SUM([SIGNUPS]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='running rate label - month' datatype='real' default-format='p0%' name='[Calculation_4567705564212731913]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 7]&#10;&#10;WHEN 0 THEN NULL&#10;WHEN 1 THEN IF LAST()==0 THEN &#10;RUNNING_SUM(SUM(SALES))/&#10;RUNNING_SUM(SUM([SIGNUPS]))&#10;END&#10;WHEN 2 THEN IF RANK_UNIQUE(&#10;RUNNING_SUM(SUM(SALES))/&#10;RUNNING_SUM(SUM([SIGNUPS])),&apos;asc&apos;) &lt; 3 &#10;OR&#10;RANK_UNIQUE(&#10;RUNNING_SUM(SUM(SALES))/&#10;RUNNING_SUM(SUM([SIGNUPS])),&apos;desc&apos;) &lt; 3&#10;OR&#10;LAST()==0&#10;&#10; THEN &#10;RUNNING_SUM(SUM(SALES))/&#10;RUNNING_SUM(SUM([SIGNUPS]))&#10;END&#10;&#10;&#10;&#10;WHEN 3 THEN &#10;RUNNING_SUM(SUM(SALES))/&#10;RUNNING_SUM(SUM([SIGNUPS]))&#10;&#10;&#10;&#10;END'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column caption='Filter: This Year  (caldate)' datatype='boolean' name='[Filter: This Month  (caldate)  (copy)_222294869561798685]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='DATETRUNC(&apos;year&apos;,[Parameters].[Parameter 7 2]) = DATETRUNC(&apos;year&apos;,[CREATED_DATE])&#10;AND&#10;DATETRUNC(&apos;month&apos;,[CALENDAR (LOCAL_MONTHLY_TARGET1)]) &lt;= DATETRUNC(&apos;month&apos;,[Parameters].[Parameter 7 2])' />
            </column>
            <column caption='Helper: EOY' datatype='datetime' name='[Filter: This Year  (caldate) (copy)_222294869569908772]' role='dimension' type='quantitative'>
              <calculation class='tableau' formula='DATEADD(&apos;month&apos;,-1,&#10;MAKEDATE(YEAR([Parameters].[Parameter 7 2]),12,31)&#10;)' />
            </column>
            <column caption='Helper: SOY' datatype='date' name='[Helper: EOY (copy)_6254303620799926276]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='DATE(DATETRUNC(&apos;year&apos;,[Parameters].[Parameter 7 2]))' />
            </column>
            <column aggregation='Count' datatype='string' default-type='nominal' layered='true' name='[LOTTERY]' pivot='key' role='dimension' type='nominal' user-datatype='string' visual-totals='Default' />
