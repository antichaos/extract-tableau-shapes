      <column aggregation='Sum' caption='CANCELLATION_TARGET (DAILY_TARGET__CALENDAR)' datatype='integer' default-type='quantitative' layered='true' name='[CANCELLATION_TARGET]' pivot='key' role='measure' type='quantitative' user-datatype='integer' visual-totals='Default' />
      <column aggregation='Year' datatype='date' default-type='ordinal' layered='true' name='[CREATED_DATE]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default' />
      <column aggregation='Year' datatype='date' default-type='ordinal' layered='true' name='[CUT_OFF_DATE_1]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default' />
      <column caption='helper | hierarchy label' datatype='string' name='[Calculation2 (copy)_6165779743135932443]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF MIN([main_channel label Set]) THEN &#10;&#10;// if not first in line of selected main channel&#10;IF LOOKUP(MIN([Calculation_1365575913192280064]),-1) == LOOKUP(MIN([Calculation_1365575913192280064]),0)&#10;THEN &#10;    &quot;       &gt; &quot; +  LOOKUP(MIN([SUB_CHANNEL]),0)&#10;&#10;&#10;ELSE &#10;// first of selected main-channel&#10;LOOKUP(MIN([Calculation_1365575913192280064]),0) + &quot; &gt; &quot; +  LOOKUP(MIN([SUB_CHANNEL]),0)&#10;END&#10;ELSE&#10;// all others&#10;LOOKUP(MIN([Calculation_1365575913192280064]),0)&#10;END&#10;&#10;&#10;&#10;//+ LOOKUP(min([SUB_CHANNEL]),0)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='_____yesterday' datatype='boolean' name='[Calculation_1030761382458265614]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='case [Parameters].[Parameter 3 1]&#13;&#10;when &apos;Sign ups&apos; then&#13;&#10;{&#13;&#10;   FIXED [LOTTERY]: Max( &#13;&#10;            If Not IsNull([SALES]) &#13;&#10;                Then [CREATED_DATE]&#13;&#10;            End&#13;&#10;        )&#13;&#10;} = DATEADD(&apos;day&apos;, -1, TODAY())&#13;&#10;&#13;&#10;END' />
      </column>
      <column caption='Sales vs Target T/F' datatype='boolean' name='[Calculation_1056938542402387969]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1484780519916171266] &gt; 1' />
      </column>
      <column caption='_Dynamic Month (Draw/Cal)' datatype='date' name='[Calculation_1235675163283988481 1]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE(If [Parameters].[Parameter 1] = &apos;DrawMonth&apos; &#13;&#10;    Then DATETRUNC(&apos;month&apos;,[DRAW_DATE])&#13;&#10;ElseIf [Parameters].[Parameter 1] = &apos;CalendarMonth&apos; &#13;&#10;    Then DateTrunc(&apos;month&apos;,[CREATED_DATE])&#13;&#10;End)' />
      </column>
      <column caption='_Month (draw/create)' datatype='date' name='[Calculation_1235675163283988481]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE(If [Parameters].[Parameter 1] = 1&#13;&#10;    Then DATETRUNC(&apos;month&apos;,[PLAYROUND])&#13;&#10;ElseIf [Parameters].[Parameter 1] = 2&#13;&#10;    Then DateTrunc(&apos;month&apos;,[CREATED_DATE])&#13;&#10;End)' />
      </column>
      <column caption='_is | Reporting Year ' datatype='boolean' name='[Calculation_1352768754678759426]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// only show valid reporting year options.&#13;&#10;If Year([Calculation_1235675163283988481 1]) &gt;= [Parameters].[Parameter 1 2]&#13;&#10;    Then TRUE&#13;&#10;Else FALSE&#13;&#10;End' />
      </column>
      <column caption='main_channel label' datatype='string' name='[Calculation_1365575913192280064]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ISNULL([MAIN_CHANNEL]) OR [MAIN_CHANNEL] = &quot;Other&quot; THEN &quot;Other&quot;&#10;ELSEIF [MAIN_CHANNEL] =  &quot;TeleMarketing&quot; THEN &quot;TM&quot;&#10;ELSEIF [MAIN_CHANNEL] =  &quot;FieldMarketing&quot; THEN &quot;FM&quot;&#10;ELSEIF [MAIN_CHANNEL] =  &quot;Door to Door&quot; THEN &quot;D2D&quot;&#10;ELSE [MAIN_CHANNEL]&#10;&#10;END' />
      </column>
      <column caption='Initial Payment Method label' datatype='string' name='[Calculation_1365575913194819587]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [INITIAL_PAYMENT_METHOD]&#10;WHEN &quot;No payment method&quot; THEN &quot;None&quot;&#10;WHEN &quot;DIRECT_PAYMENT_REGISTRATION&quot; THEN &quot;Direct reg.&quot;&#10;WHEN NULL THEN &quot;&lt;unknown&gt;&quot;&#10;ELSE ([INITIAL_PAYMENT_METHOD])&#10;END' />
      </column>
      <column caption='sales vs SIGNUPS (LOCAL_MONTHLY_TARGET__DRAW)' datatype='real' default-format='p0%' name='[Calculation_1429189203355848712]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([SALES])/SUM([SIGNUPS (LOCAL_MONTHLY_TARGET1)])' />
      </column>
      <column caption='channel / subchannel' datatype='integer' name='[Calculation_1429189203431362612]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='COUNTD(IF [SUB_CHANNEL] IN [main_channel label Set] THEN [SUB_CHANNEL] END)' />
      </column>
      <column caption='Sales vs Target' datatype='real' default-format='p0.0%' name='[Calculation_1484780519916171266]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='//SUM([SALES])/SUM([Signup Target])&#13;&#10;&#13;&#10;SUM([SALES])/([Calculation_3365244457370275856])' />
      </column>
      <column aggregation='Year' caption='CREATED_MONTH' datatype='date' default-type='ordinal' layered='true' name='[Calculation_15692239803277528]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default'>
        <calculation class='tableau' formula='DATE(DATETRUNC(&apos;month&apos;,[CREATED_DATE]))' />
      </column>
      <column aggregation='Year' caption='PLAYROUND (DAILY_TARGET__CALENDAR)' datatype='date' default-type='ordinal' layered='true' name='[Calculation_15692239806619865]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default'>
        <calculation class='tableau' formula='[DRAW]' />
      </column>
      <column aggregation='Year' caption='PLAYROUND (DAILY_TARGET__PLAYROUND)' datatype='date' default-type='ordinal' layered='true' name='[Calculation_15692239806759130]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default'>
        <calculation class='tableau' formula='[DRAW (LOCAL_DAILY_TARGET1)]' />
      </column>
      <column aggregation='Year' caption='PLAYROUND (MONTHLY_TARGET__CALENDAR)' datatype='date' default-type='ordinal' layered='true' name='[Calculation_15692239806869723]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default'>
        <calculation class='tableau' formula='[DRAW (LOCAL_MONTHLY_TARGET)]' />
      </column>
      <column aggregation='Year' caption='PLAYROUND (MONTHLY_TARGET__PLAYROUND)' datatype='date' default-type='ordinal' layered='true' name='[Calculation_15692239806984412]' pivot='key' role='dimension' type='ordinal' user-datatype='date' visual-totals='Default'>
        <calculation class='tableau' formula='[DRAW (LOCAL_MONTHLY_TARGET1)]' />
      </column>
      <column caption='_Lottery_Logo_filtered' datatype='boolean' name='[Calculation_1595400184336211978]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[LOTTERY]=[Parameters].[Parameter 1 1]' />
      </column>
      <column caption='_Metric ' datatype='integer' name='[Calculation_1595400184343027723]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='case[Parameters].[Parameter 3]&#13;&#10;    when 1 then SUM([SALES])&#13;&#10;    when 2 then SUM([CANCELLATION])&#13;&#10;    when 3 then ([Calculation_3365244457335033857])&#13;&#10;END' />
      </column>
      <column caption='__Sales_Dynamic' datatype='integer' default-format='n#,##0;-#,##0' name='[Calculation_1595400184347660303]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='If [Parameters].[Parameter 2] = &quot;Month&quot;&#13;&#10;    Then Sum(([SALES]))&#13;&#10;/*&#13;&#10;ElseIf [_param | Finance by Month/Cumulative] In ( &quot;Cumulative&quot;, &quot;YTD&quot;, &quot;Year to Date&quot; )&#13;&#10;    And Not IsNull(Sum( ([SALES] )))&#13;&#10;    Then Running_Sum( Sum( ([SALES] ) ))&#13;&#10;*/&#13;&#10;Else NULL&#13;&#10;&#13;&#10;End' />
      </column>
      <column caption='[_param | Chart - Type Selection] = 1 - Day' datatype='boolean' name='[Calculation_222294868786556931]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 4] = 1' />
      </column>
      <column caption='Net Signup Target (LOCAL_DAILY_TARGET__CALENDAR)' datatype='integer' default-format='*+#,##0;-#,##0' name='[Calculation_222294868788588553]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([SIGNUP_TARGET]) - SUM([CANCELLATION_TARGET])' />
      </column>
      <column caption='sales vs target bool' datatype='boolean' name='[Calculation_222294869552623637]' role='measure' type='nominal'>
        <calculation class='tableau' formula='SUM([SALES])&#10;&gt;=&#10;[Calculation_3365244457370275856]' />
      </column>
      <column caption='vs Target - if below' datatype='real' default-format='p0.0%' name='[Calculation_222294869552812054]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_222294869552623637] = FALSE THEN [Calculation_1484780519916171266] END' />
      </column>
      <column caption='Sales vs Target to Date  CAL' datatype='real' default-format='p0%' name='[Calculation_222294869561208860]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([SALES])/SUM([SIGNUP_TARGET 1])' />
      </column>
      <column caption='__latest_date' datatype='date' datatype-customized='true' name='[Calculation_229965060632166413]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='//DATE({Max([CREATED_DATE])})&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;//case [_param | Chart Selection (exclusive)]&#13;&#10;//when &apos;Sign ups&apos; then&#13;&#10;{&#13;&#10;   FIXED [LOTTERY]: Max( &#13;&#10;            If Not IsNull([SALES]) &#13;&#10;                Then [CREATED_DATE]&#13;&#10;            End&#13;&#10;        )&#13;&#10;}  &#13;&#10;/*&#13;&#10;when &apos;Cancellations&apos; then&#13;&#10;{&#13;&#10;   FIXED [LOTTERY]: Max( &#13;&#10;            If Not IsNull([CANCELLATION]) &#13;&#10;                Then [CREATED_DATE]&#13;&#10;            End&#13;&#10;        )&#13;&#10;} &#13;&#10;&#13;&#10;&#13;&#10;when &apos;Net sign ups&apos; then&#13;&#10;{&#13;&#10;   FIXED [LOTTERY]: Max( &#13;&#10;            If Not IsNull([SALES])&#13;&#10;                Then [CREATED_DATE]&#13;&#10;            End&#13;&#10;        )&#13;&#10;} &#13;&#10;&#13;&#10;END&#13;&#10;*/' />
      </column>
      <column caption='_Yesterday Text' datatype='string' name='[Calculation_229965061190053926]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='If [Calculation_1030761382458265614] = TRUE&#13;&#10;    Then &quot;Yesterday&quot;&#13;&#10;Else str(&apos;As of &apos;) + Str([Calculation_229965060632166413])&#13;&#10;End' />
      </column>
      <column caption='__default chart selection' datatype='string' name='[Calculation_2521664010559463425]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Sign ups&quot;' />
      </column>
      <column caption='Net Signups' datatype='integer' default-format='*+#,##0;-#,##0' name='[Calculation_3365244457335033857]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([SALES])-SUM([CANCELLATION])' />
      </column>
      <column caption='End of year' datatype='datetime' name='[Calculation_3365244457337745410]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='DATEADD(&apos;month&apos;,11,&#10;DATETRUNC(&apos;year&apos;,[Parameters].[Parameter 7 2])&#10;)' />
      </column>
      <column caption='_Month yeardiff' datatype='integer' name='[Calculation_3365244457350381574]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATEDIFF(&apos;year&apos;,[Calculation_1235675163283988481],{FIXED: MAX([Calculation_1235675163283988481])})' />
      </column>
      <column caption='Filter: Yesterday ' datatype='boolean' name='[Calculation_3365244457361330187]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [LOTTERY]: MAX(IF NOT ISNULL([SALES]) THEN [CREATED_DATE] END) } = [CREATED_DATE]' />
      </column>
      <column caption='Net signups &gt; 0' datatype='boolean' name='[Calculation_3365244457369051151]' role='measure' type='nominal'>
        <calculation class='tableau' formula='[Calculation_3365244457335033857] &gt; 0' />
      </column>
      <column caption='Sales Target Month (d/c)' datatype='integer' name='[Calculation_3365244457370275856]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1] &#10;WHEN 1 THEN SUM([SIGNUPS (LOCAL_MONTHLY_TARGET1)])&#10;WHEN 2 THEN SUM([SIGNUPS])&#10;END' />
      </column>
      <column caption='mom - month label SEL' datatype='datetime' name='[Calculation_3365244457378168849]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='DATETRUNC(&apos;month&apos;,IF [_Month yeardiff (copy)_3365244457351528455] == 0 THEN [Calculation_1235675163283988481] END)' />
