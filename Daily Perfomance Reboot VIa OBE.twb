        <calculation class='tableau' formula='//DATE({Max([CREATED_DATE])})&#13;&#10;&#13;&#10;&#13;&#10;&#13;&#10;//case [_param | Chart Selection (exclusive)]&#13;&#10;//when &apos;Sign ups&apos; then&#13;&#10;{&#13;&#10;   FIXED [LOTTERY]: Max( &#13;&#10;            If Not IsNull([SALES]) &#13;&#10;                Then [CREATED_DATE]&#13;&#10;            End&#13;&#10;        )&#13;&#10;}  &#13;&#10;/*&#13;&#10;when &apos;Cancellations&apos; then&#13;&#10;{&#13;&#10;   FIXED [LOTTERY]: Max( &#13;&#10;            If Not IsNull([CANCELLATION]) &#13;&#10;                Then [CREATED_DATE]&#13;&#10;            End&#13;&#10;        )&#13;&#10;} &#13;&#10;&#13;&#10;&#13;&#10;when &apos;Net sign ups&apos; then&#13;&#10;{&#13;&#10;   FIXED [LOTTERY]: Max( &#13;&#10;            If Not IsNull([SALES])&#13;&#10;                Then [CREATED_DATE]&#13;&#10;            End&#13;&#10;        )&#13;&#10;} &#13;&#10;&#13;&#10;END&#13;&#10;*/' />
      </column>
      <column caption='_Yesterday Text' datatype='string' hidden='true' name='[Calculation_229965061190053926]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='If [Calculation_1030761382458265614] = TRUE&#13;&#10;    Then &quot;Yesterday&quot;&#13;&#10;Else str(&apos;As of &apos;) + Str([Calculation_229965060632166413])&#13;&#10;End' />
      </column>
