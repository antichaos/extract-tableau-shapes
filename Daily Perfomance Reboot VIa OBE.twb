      <column caption='_User_location' datatype='string' hidden='true' name='[Calculation_4447938013405458446]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF ENDSWITH(USERNAME(), &quot;.co.uk&quot;) THEN &quot;PPL&quot;&#10;ELSEIF ENDSWITH(USERNAME(), &quot;.de&quot;) THEN &quot;DPL&quot;&#10;ELSEIF ENDSWITH(USERNAME(), &quot;.nl&quot;) THEN &quot;NPL&quot;&#10;ELSEIF ENDSWITH(USERNAME(), &quot;.se&quot;) THEN &quot;SPL&quot;&#10;ELSE &quot;NPL&quot; // Default if no match&#10;END' />
      </column>
